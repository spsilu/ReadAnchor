{
  "manifest_version": 3,
  "name": "Page Anchor Pro",
  "version": "1.0",
  "description": "在网页上打标签定位，快速滑动跳转。",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["loader.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
